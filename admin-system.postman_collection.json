				{
					"name": "获取举报统计",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('状态码为 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('返回数据结构正确', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.code).to.eql(200);",
									"    pm.expect(jsonData.data).to.have.property('total');",
									"    pm.expect(jsonData.data).to.have.property('pending');",
									"    pm.expect(jsonData.data).to.have.property('processing');",
									"    pm.expect(jsonData.data).to.have.property('processed');",
									"});",
									"",
									"console.log('✅ 举报统计获取成功');",
									"var data = pm.response.json().data;",
									"console.log('总举报数:', data.total);",
									"console.log('待处理:', data.pending);",
									"console.log('处理中:', data.processing);",
									"console.log('已处理:', data.processed);"
								],
								"type": "text/javascript"
							}
						}
					],
