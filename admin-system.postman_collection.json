		{
			"name": "系统设置",
			"item": [
				{
					"name": "获取系统设置",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('状态码为 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('返回数据是数组', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.code).to.eql(200);",
									"    pm.expect(jsonData.data).to.be.an('array');",
									"});",
									"",
									"console.log('✅ 系统设置获取成功');",
									"console.log('设置项数量:', pm.response.json().data.length);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/admin/settings",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "settings"]
						}
					},
					"response": []
				},
				{
					"name": "更新系统设置",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"site_name\": \"Test Campus Platform\",\n    \"allow_registration\": \"true\",\n    \"max_upload_size\": \"10485760\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/admin/settings",
							"host": ["{{baseUrl}}"],
							"path": ["admin", "settings"]
						}
					},
					"response": []
				}
			]
		},
