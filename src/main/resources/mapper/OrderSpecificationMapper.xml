<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.OrderSpecificationMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.entity.OrderSpecification">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="spec_id" property="specId"/>
        <result column="spec_name" property="specName"/>
        <result column="spec_value" property="specValue"/>
        <result column="spec_icon" property="specIcon"/>
        <result column="quantity" property="quantity"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 根据订单 ID 获取所有规格 -->
    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT * 
        FROM order_specifications 
        WHERE order_id = #{orderId}
    </select>

    <!-- 批量插入订单规格 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO order_specifications 
        (order_id, spec_id, spec_name, spec_value, spec_icon, quantity)
        VALUES
        <foreach collection="specifications" item="spec" separator=",">
            (#{spec.orderId}, #{spec.specId}, #{spec.specName}, #{spec.specValue}, 
             #{spec.specIcon}, #{spec.quantity})
        </foreach>
    </insert>

</mapper>
