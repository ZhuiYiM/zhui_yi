<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.ProductSpecificationMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.entity.ProductSpecification">
        <id column="id" property="id"/>
        <result column="product_id" property="productId"/>
        <result column="spec_name" property="specName"/>
        <result column="spec_value" property="specValue"/>
        <result column="spec_icon" property="specIcon"/>
        <result column="stock_quantity" property="stockQuantity"/>
        <result column="price_adjustment" property="priceAdjustment"/>
        <result column="is_default" property="isDefault"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 根据商品 ID 获取所有规格 -->
    <select id="selectByProductId" resultMap="BaseResultMap">
        SELECT * 
        FROM product_specifications 
        WHERE product_id = #{productId}
        ORDER BY sort_order, spec_name, spec_value
    </select>

    <!-- 批量插入规格 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO product_specifications 
        (product_id, spec_name, spec_value, spec_icon, stock_quantity, price_adjustment, is_default, sort_order)
        VALUES
        <foreach collection="specifications" item="spec" separator=",">
            (#{spec.productId}, #{spec.specName}, #{spec.specValue}, #{spec.specIcon}, 
             #{spec.stockQuantity}, #{spec.priceAdjustment}, #{spec.isDefault}, #{spec.sortOrder})
        </foreach>
    </insert>

    <!-- 删除商品的所有规格 -->
    <delete id="deleteByProductId">
        DELETE FROM product_specifications WHERE product_id = #{productId}
    </delete>

</mapper>
