{
  "info": {
    "name": "消息中心功能测试",
    "description": "消息中心完整功能测试集合，包括私信、系统消息、订单通知等",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. 发送私信",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{user1_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"toUserId\": 1002,\n  \"content\": \"你好，这是一条测试私信\",\n  \"type\": \"private_message\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/messages",
          "host": ["{{base_url}}"],
          "path": ["api", "messages"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"返回成功消息\", function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include(\"发送成功\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. 获取私信列表",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{user2_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/messages?type=private_message&page=1&size=10",
          "host": ["{{base_url}}"],
          "path": ["api", "messages"],
          "query": [
            {
              "key": "type",
              "value": "private_message"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"返回消息列表\", function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.exist;",
              "    pm.expect(jsonData.data.records).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"消息包含发送者信息\", function() {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.data.records.length > 0) {",
              "        var message = jsonData.data.records[0];",
              "        pm.expect(message.senderName).to.exist;",
              "        pm.expect(message.senderAvatar).to.exist;",
              "    }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. 获取系统消息",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{user1_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/messages?type=system&page=1&size=10",
          "host": ["{{base_url}}"],
          "path": ["api", "messages"],
          "query": [
            {
              "key": "type",
              "value": "system"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. 获取未读消息数",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{user1_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/messages/unread-count",
          "host": ["{{base_url}}"],
          "path": ["api", "messages", "unread-count"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"返回未读数量\", function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.exist;",
              "    pm.expect(jsonData.data).to.be.a(\"number\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. 标记消息为已读",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "{{user1_token}}"
