    },
    {
      "name": "8. 获取全部消息",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{user1_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api-messages?type=&page=1&size=20",
          "host": ["{{base_url}}"],
          "path": ["api", "messages"],
          "query": [
            {
              "key": "type",
              "value": ""
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"验证分页数据\", function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.records).to.be.an(\"array\");",
              "    pm.expect(jsonData.data.total).to.exist;",
              "    pm.expect(jsonData.data.current).to.equal(1);",
              "    pm.expect(jsonData.data.size).to.equal(20);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9. 发送私信 - 内容为空（失败场景）",
