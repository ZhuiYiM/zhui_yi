        },
        "url": {
          "raw": "{{base_url}}/api/messages",
          "host": ["{{base_url}}"],
          "path": ["api", "messages"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码不为 200\", function() {",
              "    pm.response.to.not.have.status(200);",
              "});",
